@model IEnumerable<TravelWeb.Areas.TripProduct.Models.ViewModels.OrderIndexViewModel>
@{
    ViewData["Title"] = "商家訂單管理中心";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var summary = ViewBag.Summary as TravelWeb.Areas.TripProduct.Models.ViewModels.OrderSummaryViewModel;
}

<div class="container-fluid py-4">
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <a href="#orderList" class="card-link">
                <div class="card border-0 shadow-sm bg-primary text-white h-100 summary-card">
                    <div class="card-body p-4 text-center">
                        <h6 class="text-uppercase opacity-75">今日預計出團</h6>
                        <h2 class="display-5 fw-bold mb-0">@summary?.TodayTripsCount <small class="fs-6">團/張</small></h2>
                        <small class="opacity-75">點擊查看詳情</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="#orderList" class="card-link">
                <div class="card border-0 shadow-sm bg-danger text-white h-100 summary-card">
                    <div class="card-body p-4 text-center">
                        <h6 class="text-uppercase opacity-75">未付款訂單</h6>
                        <h2 class="display-5 fw-bold mb-0">@summary?.UnpaidCount</h2>
                        <small class="opacity-75">點擊查看詳情</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="#orderList" class="card-link">
                <div class="card border-0 shadow-sm bg-warning text-dark h-100 summary-card">
                    <div class="card-body p-4 text-center">
                        <h6 class="text-uppercase opacity-75">待處理/已付款</h6>
                        <h2 class="display-5 fw-bold mb-0">@summary?.PendingConfirmationCount</h2>
                        <small class="opacity-75">點擊查看詳情</small>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" id="orderList">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>即時訂單列表</h5>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary">匯出報表</button>
                <button class="btn btn-outline-secondary">顯示設定</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted text-uppercase" style="font-size: 0.85rem;">
                        <tr>
                            <th class="ps-4" style="width: 120px;">狀態</th>
                            <th>訂單編號</th>
                            <th>顧客資訊</th>
                            <th>活動日期 / 類型</th>
                            <th>商品摘要</th>
                            <th class="text-end pe-4">金額</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <span class="status-dot @item.StatusLightClass me-2"></span>
                                        <span class="small fw-bold text-secondary">@item.OrderStatus</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold text-dark">@item.OrderNumber</span><br />
                                    <small class="text-muted">@item.CreatedAt.ToString("MM/dd HH:mm")</small>
                                </td>
                                <td>
                                    <div class="fw-bold">@item.CustomerName</div>
                                    <small class="text-muted">@item.ContactPhone</small>
                                </td>
                                <td>
                                    @if (item.TravelDate.HasValue)
                                    {
                                        <div class="badge bg-light text-primary border border-primary-subtle">
                                            <i class="bi bi-calendar3 me-1"></i> @item.TravelDate.Value.ToString("yyyy-MM-dd")
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="badge bg-light text-secondary border border-secondary-subtle">
                                            <i class="bi bi-ticket-detailed me-1"></i> 一般票券
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 200px;">@item.ProductSummary</div>
                                    @if (item.HasCustomerNote)
                                    {
                                        <span class="badge rounded-pill bg-info text-dark mt-1"><i class="bi bi-chat-dots"></i> 備註</span>
                                    }
                                </td>
                                <td class="text-end pe-4 fw-bold text-primary">@item.TotalAmount.ToString("C0")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-primary px-3 shadow-sm">詳情</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* 讓卡片看起來可以點擊 */
        .card-link {
            text-decoration: none !important;
            display: block;
            transition: transform 0.2s ease-in-out;
        }

            .card-link:hover {
                transform: translateY(-5px);
            }

        .summary-card {
            cursor: pointer;
        }

        /* 狀態燈強化 */
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        /* 這裡可以根據你的 StatusLightClass 補上顏色，例如： */
        .bg-success {
            background-color: #28a745 !important;
        }

        .bg-warning {
            background-color: #ffc107 !important;
        }

        .bg-danger {
            background-color: #dc3545 !important;
        }

        /* 跳轉平滑捲動 */
        html {
            scroll-behavior: smooth;
        }
    </style>
}