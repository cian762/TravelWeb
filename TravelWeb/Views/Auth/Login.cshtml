@{
    // 🌟 加入這行，讓此頁面「不套用」原本有側邊欄的 Layout
    Layout = null;
    ViewData["Title"] = "後台管理系統 - 登入";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- 🌟 因為拿掉了 Layout，需要自行引入 Bootstrap，版面才不會壞掉 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* 確保背景填滿視窗 */
        body {
            background-color: #f8f9fa;
            margin: 0;
            padding: 0;
        }
    </style>
</head>
<body>

    <div class="d-flex justify-content-center align-items-center vh-100 bg-light">
        <div class="card shadow-lg p-4" style="width:400px; border-radius:15px;">
            <h3 class="text-center mb-4">後台系統登入</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger" style="color: red; margin-bottom: 15px;">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">

                <div class="mb-3">
                    <label class="form-label">管理員帳號</label>
                    <input type="text" name="account" class="form-control"
                           placeholder="請輸入 信箱 或 ID" required />
                </div>

                <div class="mb-3 position-relative">
                    <label class="form-label">密碼</label>
                    <input type="password" name="password" id="passwordInput"
                           class="form-control" placeholder="請輸入密碼" required />

                    <span onclick="togglePassword()"
                          style="position:absolute; right:15px; top:38px; cursor:pointer;">
                        👁️
                    </span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        登入
                    </button>
                </div>

            </form>

            <!-- 如果這是純後台登入，通常不會開放前台直接註冊，你可以考慮把這行拿掉或隱藏 -->
            @* 
            <div class="text-center mt-3">
                <a href="/MemberAccount/Create">還沒有帳號？註冊</a>
            </div> 
            *@

        </div>
    </div>

    <script>
        function togglePassword() {
            var input = document.getElementById("passwordInput");

            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }
    </script>

    <!-- 引入 Bootstrap JS (如果有用到互動元件的話) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>