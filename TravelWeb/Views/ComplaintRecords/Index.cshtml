@model IEnumerable<TravelWeb.Models.ComplaintRecord>

@{
    ViewData["Title"] = "客訴案件管理";
    // 從 ViewBag 取得當前登入者的角色 (Member 或 Admin)
    var userRole = ViewBag.Role as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-headset"></i> 客訴案件管理</h2>

        <!-- 會員可以點擊新增客訴 -->
        @if (userRole == "Member")
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> 新增客訴
            </a>
        }
    </div>

    <!-- ========================================== -->
    <!-- 📊 統計圖表區塊 (Chart.js) -->
    <!-- ========================================== -->
    <div class="card shadow-sm mb-5 border-0 rounded-4">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h5 class="fw-bold text-secondary"><i class="bi bi-bar-chart-line"></i> 每月客訴案件統計</h5>
        </div>
        <div class="card-body">
            <!-- 設定一個固定高度的畫布讓 Chart.js 畫圖 -->
            <canvas id="complaintChart" style="max-height: 300px; width: 100%;"></canvas>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- 📋 客訴案件清單區塊 -->
    <!-- ========================================== -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">案件編號</th>
                        <th>建立日期</th>
                        <th>申請人 (會員)</th>
                        <th>處理狀態</th>
                        <th>指派專員</th>
                        <th class="text-end pe-4">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                目前沒有任何客訴案件紀錄。
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            // 解析編號中的日期 (假設格式為 20231027001)
                            string dateStr = item.ComplaintId?.Length >= 8
                            ? $"{item.ComplaintId.Substring(0, 4)}/{item.ComplaintId.Substring(4, 2)}/{item.ComplaintId.Substring(6, 2)}"
                            : "未知日期";

                            // 根據狀態給予不同的顏色標籤 (Badge)
                            string badgeClass = item.Status switch
                            {
                                "已檢視" => "bg-secondary",
                                "已審核" => "bg-warning text-dark",
                                "已立案" => "bg-info text-dark",
                                "已處理" => "bg-success",
                                _ => "bg-secondary"
                            };

                            <tr>
                                <td class="ps-4 fw-bold text-primary">@item.ComplaintId</td>
                                <td>@dateStr</td>
                                <td>@item.MemberCode</td>

                                <!-- 狀態欄位 -->
                                <td>
                                    <!-- 如果是管理員，顯示下拉選單讓他可以快速修改 (這裡示範唯讀標籤，修改可另做獨立頁面) -->
                                    <span class="badge @badgeClass fs-6 px-3 py-2 rounded-pill shadow-sm">
                                        @item.Status
                                    </span>
                                </td>

                                <!-- 指派專員 -->
                                <td class="text-muted">
                                    @(string.IsNullOrEmpty(item.AdminId) ? "尚未指派" : item.AdminId)
                                </td>

                                <!-- 操作按鈕：進入詳細頁面查看 Compensation -->
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.ComplaintId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-eye"></i> 查看詳細與處理結果
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ========================================== -->
<!-- 引入 Chart.js 套件與繪製圖表的腳本 -->
<!-- ========================================== -->
@section Scripts {
    <!-- 引入 Chart.js (CDN) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 從 Controller 的 ViewBag 接回 JSON 格式的圖表資料
            // Html.Raw() 是為了解析 JSON 字串，避免引號被 HTML 編碼
            const rawLabels = '@Html.Raw(ViewBag.ChartLabels)';
            const rawCounts = '@Html.Raw(ViewBag.ChartCounts)';

            // 如果沒有資料，就不畫圖
            if (!rawLabels || rawLabels === 'null') return;

            const labels = JSON.parse(rawLabels);
            const dataCounts = JSON.parse(rawCounts);

            const ctx = document.getElementById('complaintChart').getContext('2d');

            new Chart(ctx, {
                type: 'bar', // 長條圖 (也可改為 'line' 折線圖)
                data: {
                    labels: labels, // X 軸：月份
                    datasets: [{
                        label: '客訴案件數量',
                        data: dataCounts, // Y 軸：數量
                        backgroundColor: 'rgba(54, 162, 235, 0.6)', // 柱狀圖顏色 (藍色半透明)
                        borderColor: 'rgba(54, 162, 235, 1)',       // 邊框顏色
                        borderWidth: 1,
                        borderRadius: 5 // 柱狀圖圓角
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false // 隱藏上方的圖例標籤
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1 // Y 軸刻度以整數跳動
                            }
                        }
                    }
                }
            });
        });
    </script>
}