@model TravelWeb.Models.MemberList

@{
    ViewData["Title"] = "註冊會員";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <!-- 美化的註冊卡片 -->
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 border-0 rounded-top-4">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill"></i> 註冊新會員</h3>
                    <small class="text-light">請填寫以下資訊建立您的帳號</small>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Create" method="post">

                        <!-- 顯示系統錯誤訊息區塊 -->
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <!-- Email -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Email 信箱</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- 第一行密碼 (依需求：顯示明碼 type="text") -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">設定密碼 (顯示)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-unlock"></i></span>
                                <input asp-for="PasswordHash" type="text" class="form-control" placeholder="請設定您的密碼" />
                            </div>
                            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                        </div>

                        <!-- 第二行確認密碼 (依需求：隱藏密碼 type="password") -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">再次輸入密碼 (隱藏)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-lock-fill"></i></span>
                                <!-- 注意：這裡的 name="confirmPassword" 必須對應到 Controller 裡的新參數 -->
                                <input name="confirmPassword" type="password" class="form-control" placeholder="請再次輸入密碼確認" required />
                            </div>
                        </div>

                        <!-- 電話 -->
                        <div class="mb-4">
                            <label asp-for="Phone" class="form-label fw-bold text-secondary">聯絡電話</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Phone" class="form-control" placeholder="09xx-xxxxxx" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <!-- 按鈕區塊 (已精簡) -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold rounded-pill">
                                確認註冊
                            </button>
                            <button type="reset" class="btn btn-light btn-lg text-secondary border shadow-sm rounded-pill mt-2">
                                清除重填
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}