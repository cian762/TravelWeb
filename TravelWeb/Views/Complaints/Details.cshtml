@model TravelWeb.Models.MemberComplaint

@{
    ViewData["Title"] = "客訴詳細內容";

    // 解析日期 (從 20231027001 擷取前 8 碼轉為日期格式)
    string dateStr = Model.ComplaintId?.Length >= 8
        ? $"{Model.ComplaintId.Substring(0, 4)}/{Model.ComplaintId.Substring(4, 2)}/{Model.ComplaintId.Substring(6, 2)}"
        : "未知日期";

    // 判斷目前進度 (用於畫進度條)
    int progressPercent = @Model.Complaint?.Status switch
    {
        "已檢視" => 25,
        "已審核" => 50,
        "已立案" => 75,
        "已處理" => 100,
        _ => 0
    };
}

<div class="container mt-4">
    <!-- 頁面標題與返回按鈕 -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-file-earmark-text"></i> 客訴案件詳細資訊</h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> 返回清單
        </a>
    </div>

    <div class="row">
        <!-- 左側：案件基本資訊與狀態進度 -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-light border-0 pt-4 pb-2 px-4">
                    <h5 class="fw-bold text-dark mb-0">案件狀態</h5>
                </div>
                <div class="card-body px-4">
                    <h3 class="text-primary fw-bold mb-1">@Model.ComplaintId</h3>
                    <p class="text-muted small mb-4">建立日期：@dateStr</p>

                    <!-- 視覺化狀態進度條 -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between small text-muted mb-1 fw-bold">
                            <span>已檢視</span>
                            <span>已處理</span>
                        </div>
                        <div class="progress" style="height: 10px; border-radius: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                                 role="progressbar"
                                 style="width: @progressPercent%;"
                                 aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="text-center mt-2">
                            <span class="badge bg-primary fs-6 px-3 py-2 rounded-pill shadow-sm">當前狀態：@Model.Complaint?.Status</span>
                        </div>
                    </div>

                    <hr />

                    <div class="mt-4">
                        <p class="mb-2"><i class="bi bi-person-badge text-secondary"></i> <strong>申請會員：</strong> @Model.Member?.MemberCode</p>
                        <p class="mb-0">
                            <i class="bi bi-person-workspace text-secondary"></i> <strong>負責專員：</strong>
                            @(string.IsNullOrEmpty(@Model.Complaint?.AdminId) ? "尚未指派" : @Model.Complaint?.AdminId)
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 右側：詳細內容 / 補償方案 (Compensation) -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold text-secondary"><i class="bi bi-chat-square-text"></i> 案件詳細內容與處理結果 (Compensation)</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="p-4 bg-light rounded-3" style="min-height: 250px; font-size: 1.1rem; line-height: 1.8;">
                        @if (string.IsNullOrEmpty(@Model.Complaint?.Compensation))
                        {
                            <div class="text-center text-muted mt-5">
                                <i class="bi bi-hourglass-split fs-1 d-block mb-3"></i>
                                專員尚未填寫詳細處理結果或補償方案。
                            </div>
                        }
                        else
                        {
                            <!-- 使用 Html.Raw() 保留換行格式，或用 pre 標籤包住 -->
                            <span class="text-dark">@Model.Complaint?.Compensation</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>